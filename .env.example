# Application settings
PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000

# Database settings
DATABASE_URL=postgresql://admin:admin123@postgres_db:5432/nest_db
DATABASE_HOST=postgres_db
DATABASE_PORT=5432
DATABASE_USER=admin
DATABASE_PASSWORD=admin123
DATABASE_NAME=nest_db

# Security settings
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=your_even_more_secret_refresh_key_here
REFRESH_TOKEN_EXPIRES_IN=7d

# Socket.io settings
SOCKET_PORT=3001
